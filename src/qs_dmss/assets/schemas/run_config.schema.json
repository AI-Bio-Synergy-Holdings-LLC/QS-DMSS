{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QS-DMSS Run Config",
  "type": "object",
  "required": ["run", "engine", "initial"],
  "additionalProperties": false,
  "properties": {
    "run": {
      "type": "object",
      "required": ["name", "seed"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        },
        "output_root": {
          "type": "string",
          "default": "runs"
        }
      }
    },
    "engine": {
      "type": "object",
      "required": [
        "backend",
        "grid_shape",
        "box_size",
        "mass",
        "g_int",
        "time_step",
        "num_steps"
      ],
      "additionalProperties": false,
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["numpy"]
        },
        "grid_shape": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "integer",
            "minimum": 2
          }
        },
        "box_size": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "mass": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "g_int": {
          "type": "number"
        },
        "time_step": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "num_steps": {
          "type": "integer",
          "minimum": 1
        },
        "log_every": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        }
      }
    },
    "initial": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["gaussian", "uniform"]
        },
        "amplitude": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 1.0
        },
        "width": {
          "type": "number",
          "exclusiveMinimum": 0,
          "default": 0.2
        },
        "random_phase": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "objective": {
      "type": "object",
      "required": ["name", "primary_metric", "goal"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "primary_metric": {
          "type": "string",
          "enum": ["energy_drift", "norm_drift", "max_density", "elapsed_seconds"]
        },
        "goal": {
          "type": "string",
          "enum": ["minimize", "minimize_abs", "maximize", "target"]
        },
        "target_value": {
          "type": "number"
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_abs_energy_drift": {
          "type": "number",
          "minimum": 0
        },
        "max_abs_norm_drift": {
          "type": "number",
          "minimum": 0
        },
        "min_max_density": {
          "type": "number"
        },
        "max_elapsed_seconds": {
          "type": "number",
          "minimum": 0
        },
        "require_verification": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "ranking": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "primary_metric_weight": {
          "type": "number",
          "minimum": 0,
          "default": 2.0
        },
        "weights": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "energy_drift": {
              "type": "number",
              "minimum": 0
            },
            "norm_drift": {
              "type": "number",
              "minimum": 0
            },
            "max_density": {
              "type": "number",
              "minimum": 0
            },
            "elapsed_seconds": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "campaign": {
      "type": "object",
      "required": ["label", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "strategy": {
          "type": "string",
          "enum": ["grid"],
          "default": "grid"
        },
        "max_runs": {
          "type": "integer",
          "minimum": 2,
          "default": 16
        },
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["path", "values"],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "enum": [
                  "engine.g_int",
                  "engine.time_step",
                  "engine.num_steps",
                  "initial.amplitude",
                  "initial.width",
                  "run.seed"
                ]
              },
              "values": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}
